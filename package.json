  "main": "index.js",
  "scripts": {
  "test":               "playwright test",
  "test:ui":            "playwright test tests/webUI/todo.spec.ts",
  "test:api":           "playwright test tests/api/",
  "test:conduit":       "playwright test tests/api/conduit.api.spec.ts --project=api",
  "test:smoke":         "playwright test --grep @smoke",
  "test:staging":       "TEST_ENV=staging playwright test",
  "test:prod":          "TEST_ENV=production playwright test",
  "report":             "playwright show-report",
  "typecheck":          "tsc --noEmit",
  "generate:tests":     "ts-node ai-generator/requirementToTestCases.ts",
  "generate:scaffold":  "ts-node ai-generator/testCasesToScaffold.ts"
},

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"]
  },
  "include": [
    "tests/**/*",
    "lib/**/*",
    "utils/**/*",
    "fixtures/**/*",
    "ai-generator/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
